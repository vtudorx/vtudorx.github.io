# Hugo build artifacts
/public/
/resources/
/.hugo_build.lock

# Local editor and tool state
.DS_Store
/.claude/
/.idea/*
!/.idea/.gitignore

# Local environment files
.env
.env.*
!.env.example

# Node dependencies and package-manager caches
/node_modules/
.npm/
.pnpm-store/
.yarn/
!.yarn/releases/
!.yarn/plugins/
!.yarn/sdks/
!.yarn/versions/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
